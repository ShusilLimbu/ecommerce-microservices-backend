{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "E-commerce microservices: auth, user, order",
  "workspaces": ["packages/*", "services/*", "api-gateway"],
  "scripts": {
    "dev:auth": "npm run dev -w auth-service",
    "dev:user": "npm run dev -w user-service",
    "dev:order": "npm run dev -w order-service",
    "dev:gateway": "npm run dev -w api-gateway",
    "migrate:all": "npm run migrate -w auth-service && npm run migrate -w user-service && npm run migrate -w order-service",
    "ci:check": "bash deploy/scripts/ci-check.sh"
  }
}
