# Local development (copy to .env in each service or use these defaults)
JWT_SECRET=dev-jwt-secret-change-in-production
INTERNAL_API_KEY=dev-internal-key
RABBITMQ_URL=amqp://localhost:5672

# Auth
PORT=3001
DATABASE_URL=postgresql://ecommerce:ecommerce_secret@localhost:5432/auth_db
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=7

